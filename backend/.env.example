# ================================================
# SERENUS - VARIÁVEIS DE AMBIENTE
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env no git
# ================================================

# ---- SERVIDOR ----
NODE_ENV=production
PORT=3001

# ---- BANCO DE DADOS (PostgreSQL) ----
# Supabase: Settings > Database > Connection string (URI)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# ---- JWT ----
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GERE_UM_SECRET_FORTE_AQUI
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ---- E-MAIL (Resend ou SMTP) ----
# Resend.com: gratuito até 3000 emails/mês
RESEND_API_KEY=re_XXXXXXXXXXXX
EMAIL_FROM=noreply@serenus.com.br
EMAIL_FROM_NAME=Serenus

# ---- ARMAZENAMENTO (Supabase Storage) ----
SUPABASE_URL=https://[PROJECT].supabase.co
SUPABASE_ANON_KEY=eyXXXXXXXXXXXXXXX
SUPABASE_SERVICE_KEY=eyXXXXXXXXXXXXXXX

# ---- FRONTEND ----
FRONTEND_URL=https://serenus.vercel.app

# ---- RATE LIMITING ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
